{
  "name": "aiagent2",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "help": "node scripts/help.mjs",
    "help:cli": "node scripts/help.mjs cli",
    "help:qa": "node scripts/help.mjs qa",
    "cait": "node scripts/external-chat.mjs",
    "seo:build": "node scripts/generate-seo-pages.mjs",
    "open-core:export": "node scripts/export-open-core.mjs",
    "open-core:sync": "node scripts/export-open-core.mjs ../aiagent2-core --clean",
    "start": "npx wrangler dev --remote",
    "dev": "npx wrangler dev --remote",
    "dev:node-ephemeral": "node server.js",
    "qa:docs": "node scripts/docs-qa.mjs",
    "qa:seo": "node scripts/seo-qa.mjs",
    "qa:settings": "node scripts/settings-qa.mjs",
    "qa:storage": "node scripts/storage-qa.mjs",
    "qa:feedback": "node scripts/feedback-qa.mjs",
    "qa:api-keys": "node scripts/api-keys-qa.mjs",
    "qa:auth": "node scripts/auth-link-qa.mjs && node scripts/email-auth-qa.mjs",
    "qa:agent-api": "node scripts/agent-api-e2e-qa.mjs",
    "qa:callback": "node scripts/callback-qa.mjs && node scripts/callback-state-guard.mjs",
    "qa:retry-timeout": "node scripts/retry-timeout-qa.mjs",
    "qa:state-machine": "node scripts/state-machine-qa.mjs",
    "qa:runs": "node scripts/runs-qa.mjs",
    "qa:manifest-verify": "node scripts/manifest-verify-qa.mjs",
    "qa:manifest-validation": "node scripts/manifest-validation-qa.mjs",
    "qa:manifest-draft": "node scripts/manifest-draft-qa.mjs",
    "qa:github-adapter": "node scripts/github-adapter-qa.mjs",
    "qa:onboarding": "node scripts/onboarding-qa.mjs",
    "qa:builtin-agents": "node scripts/builtin-agents-qa.mjs",
    "qa:open-core": "node scripts/open-core-qa.mjs",
    "qa:routing": "node scripts/routing-qa.mjs",
    "qa:recurring-orders": "node scripts/recurring-orders-qa.mjs",
    "qa:security-hardening": "node scripts/security-hardening-qa.mjs",
    "qa:billing": "node scripts/billing-qa.mjs && node scripts/billing-audit-qa.mjs",
    "qa:stripe": "node scripts/stripe-qa.mjs",
    "qa:ui": "node scripts/ui-qa.mjs",
    "qa:agent-ops": "node scripts/agent-ops-qa.mjs",
    "qa:e2e-mock": "node scripts/e2e-mock-qa.mjs",
    "qa:release-posture": "node scripts/release-posture-qa.mjs",
    "qa:worker-api": "node scripts/worker-api-qa.mjs",
    "qa:worker-runs": "node scripts/worker-runs-qa.mjs",
    "qa:leader-workflows": "node scripts/leader-workflows-qa.mjs",
    "qa:deployment-ops": "node scripts/deployment-ops-qa.mjs && node scripts/release-posture-qa.mjs && node scripts/worker-api-qa.mjs && node scripts/worker-runs-qa.mjs && node scripts/leader-workflows-qa.mjs",
    "qa:all": "npm run qa:docs && npm run qa:seo && npm run qa:settings && npm run qa:storage && npm run qa:feedback && npm run qa:api-keys && npm run qa:auth && npm run qa:agent-api && npm run qa:manifest-validation && npm run qa:manifest-draft && npm run qa:github-adapter && npm run qa:onboarding && npm run qa:builtin-agents && npm run qa:open-core && npm run qa:manifest-verify && npm run qa:routing && npm run qa:recurring-orders && npm run qa:callback && npm run qa:retry-timeout && npm run qa:state-machine && npm run qa:runs && npm run qa:security-hardening && npm run qa:billing && npm run qa:stripe && npm run qa:ui && npm run qa:e2e-mock && npm run qa:leader-workflows && npm run qa:deployment-ops"
  }
}
