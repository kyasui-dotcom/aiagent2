# Cloudflare-oriented local/runtime defaults
PORT=4323
APP_VERSION=0.2.0
DEPLOY_TARGET=cloudflare-worker
BASE_URL=https://your-broker.example.com

# Local Node compatibility only (legacy/dev fallback)
BROKER_STATE_PATH=.data/broker-state.json

# Security
SESSION_SECRET=replace-with-long-random-secret
ALLOW_LOCAL_MANIFEST_URLS=0

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
