# Cloudflare-oriented local/runtime defaults
PORT=4323
APP_VERSION=0.2.0
DEPLOY_TARGET=cloudflare-worker
PRIMARY_BASE_URL=https://aiagent-marketplace.net
ALLOWED_BASE_URLS=https://aiagent-marketplace.net,https://www.aiagent-marketplace.net,https://aiagent-market.net,https://aiagent2.net
BASE_URL=https://aiagent-marketplace.net

# Test-only local Node fallback. Hosted runtime must use Cloudflare bindings.

# Security
SESSION_SECRET=replace-with-long-random-secret
ALLOW_LOCAL_MANIFEST_URLS=0
RELEASE_STAGE=public
ALLOW_OPEN_WRITE_API=0
ALLOW_GUEST_RUN_READ_API=0
ALLOW_DEV_API=0
EXPOSE_JOB_SECRETS=0
FEEDBACK_REVIEWER_LOGINS=
AGENT_REVIEWER_LOGINS=
ADMIN_DASHBOARD_LOGINS=yasuikunihiro@gmail.com

# Feedback forwarding
# Cloudflare Worker production uses the FEEDBACK_EMAIL send_email binding in wrangler.jsonc.
# Local Node dev can optionally POST feedback email payloads to a webhook.
FEEDBACK_EMAIL_TO=support@aiagent-marketplace.net
FEEDBACK_EMAIL_DELIVERY_TO=yasuikunihiro@gmail.com
FEEDBACK_EMAIL_FROM=support@aiagent-marketplace.net
FEEDBACK_EMAIL_WEBHOOK_URL=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_SCOPE=openid email profile

# X OAuth connector
# X_TOKEN_ENCRYPTION_KEY must be base64 for exactly 32 bytes.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_TOKEN_ENCRYPTION_KEY=
X_CALLBACK_URL=

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=

# Built-in starter agents
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
BUILTIN_OPENAI_MODEL=gpt-5.4-mini
BUILTIN_OPENAI_CHEAP_MODEL=gpt-5.4-nano
BUILTIN_OPENAI_STANDARD_MODEL=gpt-5.4-mini
BUILTIN_OPENAI_REASONING_MODEL=gpt-5.4-mini
BUILTIN_OPENAI_RESEARCH_MODEL=
BUILTIN_OPENAI_WRITER_MODEL=
BUILTIN_OPENAI_CODE_MODEL=
BUILTIN_OPENAI_MODEL_BY_KIND_JSON=
BUILTIN_OPENAI_TIMEOUT_MS=45000
BUILTIN_OPENAI_INPUT_PRICE_PER_MTOK=
BUILTIN_OPENAI_OUTPUT_PRICE_PER_MTOK=

# Work Chat pre-order fallback classifier
# CAIt uses deterministic rules first. This LLM is called only for ambiguous
# pre-order intent clarification, not for actual order execution.
# Open-source/self-hosted builds keep this off unless explicitly enabled.
# OPENAI_API_KEY is only used as a Work Chat fallback for allowed operator emails.
# Set OPEN_CHAT_ALLOW_PLATFORM_OPENAI_FALLBACK=true only on an official hosted
# Web UI where the platform owner accepts Work Chat fallback usage/costs.
OPEN_CHAT_INTENT_LLM=off
OPEN_CHAT_OPENAI_API_KEY=
OPEN_CHAT_ALLOW_PLATFORM_OPENAI_FALLBACK=false
OPEN_CHAT_INTENT_ALLOWED_EMAILS=yasuikunihiro@gmail.com
OPEN_CHAT_INTENT_MODEL=gpt-5.4-nano
OPEN_CHAT_INTENT_TIMEOUT_MS=12000

# Agent registration review
AGENT_REVIEW_AI_ENABLED=1
AGENT_REVIEW_AI_ON_CLEAN=0
AGENT_REVIEW_MODEL=
AGENT_REVIEW_TIMEOUT_MS=15000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_CURRENCY=USD
STRIPE_SUBSCRIPTION_PRICES_JSON={"starter":"price_xxx","pro":"price_yyy"}
